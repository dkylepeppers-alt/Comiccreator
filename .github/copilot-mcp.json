{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "github-mcp-server",
      "args": [
        "--toolsets",
        "repos,issues,pull_requests,actions,code_security"
      ],
      "tools": ["*"]
    },
    "fetch": {
      "type": "stdio",
      "command": "fetch-mcp-server",
      "args": [],
      "tools": ["*"]
    }
  }
}
