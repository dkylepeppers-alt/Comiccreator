{
  "name": "comic-creator",
  "version": "1.6.6",
  "private": true,
  "description": "AI Comic Creator - A vanilla JS PWA for generating AI-powered comic books",
  "scripts": {
    "prepare": "bash scripts/install-hooks.sh",
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "format": "prettier --write 'js/**/*.js' 'css/**/*.css'",
    "format:check": "prettier --check 'js/**/*.js' 'css/**/*.css'",
    "test": "node --test test/*.test.js",
    "check-syntax": "for f in js/*.js js/pages/*.js; do node --check \"$f\" || exit 1; done",
    "serve": "python3 -m http.server 8080",
    "version:patch": "bash scripts/bump-version.sh patch",
    "version:minor": "bash scripts/bump-version.sh minor",
    "version:major": "bash scripts/bump-version.sh major"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "fake-indexeddb": "^6.2.5",
    "nanogptjs": "^1.0.4",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5"
  }
}
