{
  "name": "comic-creator",
  "version": "1.6.65",
  "type": "module",
  "private": true,
  "description": "AI Comic Creator - A Vite-powered PWA for generating AI-powered comic books",
  "scripts": {
    "prepare": "bash scripts/install-hooks.sh",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview --port 8080",
    "lint": "eslint src/js/",
    "lint:fix": "eslint src/js/ --fix",
    "format": "prettier --write 'src/**/*.{js,ts}' 'src/**/*.css'",
    "format:check": "prettier --check 'src/**/*.{js,ts}' 'src/**/*.css'",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "coverage:ci": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "check-syntax": "npm run typecheck && npm run build -- --logLevel error",
    "update-docs": "bash scripts/update-docs.sh",
    "lint:actions": "bash scripts/check-actions.sh",
    "validate:workflows": "bash scripts/validate-workflows.sh",
    "version:patch": "bash scripts/bump-version.sh patch",
    "version:minor": "bash scripts/bump-version.sh minor",
    "version:major": "bash scripts/bump-version.sh major"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "nanogptjs": "^1.0.4",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
